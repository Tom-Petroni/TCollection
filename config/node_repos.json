{
  "schema_version": "1.0",
  "owner": "Tom-Petroni",
  "repo_name_pattern": "{key}",
  "default_provider": "github-release",
  "defaults": {
    "tag_pattern": "v{version}",
    "asset_name_pattern": "{key}-v{version}.zip",
    "archive_root_pattern": "{key}-{version}",
    "repo_url_pattern": "https://github.com/{repo_full}",
    "releases_url_pattern": "https://github.com/{repo_full}/releases"
  },
  "nodes": {
    "TBlur": {
      "enabled": true,
      "repo": "Tom-Petroni/TBlur"
    },
    "TColorRamp": {
      "enabled": true,
      "repo": "Tom-Petroni/TColorRamp"
    },
    "TMask": {
      "enabled": true,
      "repo": "Tom-Petroni/TMask"
    },
    "TNoise": {
      "enabled": true,
      "repo": "Tom-Petroni/TNoise"
    },
    "TNormalRelight": {
      "enabled": false,
      "repo": "Tom-Petroni/TNormalRelight"
    },
    "TSMAA": {
      "enabled": false,
      "repo": "Tom-Petroni/TSMAA"
    },
    "TScatter": {
      "enabled": false,
      "repo": "Tom-Petroni/TScatter"
    },
    "BrushScatter": {
      "enabled": false,
      "repo": "Tom-Petroni/BrushScatter"
    },
    "PRefToMotion": {
      "enabled": false,
      "repo": "Tom-Petroni/PRefToMotion"
    },
    "OnlyRender": {
      "enabled": false,
      "repo": "Tom-Petroni/OnlyRender"
    }
  }
}
